# Server
PORT=8082
NODE_ENV=development

# Database
DATABASE_PATH=./data/opium.db

# Security
ENCRYPTION_KEY=your-32-byte-hex-key-here-for-aes256
API_KEY_SALT_ROUNDS=12
MASTER_API_KEY=your-master-api-key-for-user-registration

# OAuth (Anthropic)
# This is the "opencode" client ID registered with Anthropic
ANTHROPIC_CLIENT_ID=9d1c250a-e61b-44d9-88ed-5944d1962f5e
ANTHROPIC_REDIRECT_URI=https://console.anthropic.com/oauth/code/callback

# Logging
LOG_LEVEL=info
ENABLE_REQUEST_LOGGING=false
